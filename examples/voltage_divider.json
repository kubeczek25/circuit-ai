    { "id": "R2", "kind": "resistor", "node_from": "n2", "node_to": "gnd", "value": 1000.0 }
  ],
  "targets": [
    { "element_id": "R2", "target_type": "voltage" },
    { "element_id": "R1", "target_type": "current" }
  ]
